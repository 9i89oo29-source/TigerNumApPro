NODE_ENV=production
PORT=3000

MONGODB_URI=mongodb://localhost:27017/tigernum
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_SECRET=your-256-bit-secret-change-in-production
JWT_REFRESH_SECRET=your-other-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

HERO_API_KEY=hero_provider_api_key_here
TIGER_API_KEY=tiger_provider_api_key_here

ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$10$... (bcrypt hash of password)

LOG_LEVEL=info
